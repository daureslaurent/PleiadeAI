# --- Core ---
NODE_ENV=development
PORT=4000

# --- Persistence & inference ---
MONGO_URI=mongodb://localhost:27017/pleiades
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# The agent loop drives tools via NATIVE OpenAI-style function calling. For the model to emit tool
# calls on the structured `tool_calls` channel (instead of leaking them as text like `[ask_user] …`),
# the remote llama.cpp server MUST be launched with `--jinja` and a chat template that supports tool
# calls — e.g. `llama-server --jinja -m model.gguf` (add `--chat-template <name>` if the GGUF's
# embedded template lacks tool support). Without this, agents narrate calls as prose and tools don't
# run; the backend has a best-effort text→tool-call fallback, but `--jinja` is the real fix.
LLAMA_API_URL=http://192.168.1.100:8080
LLAMA_API_KEY=sk-no-key-required
LLAMA_MODEL=local-model
# Model context window (n_ctx); default when Settings has none. Shown as the chat context meter's denominator.
LLAMA_CONTEXT_WINDOW=8192

# Built-in local fallback (docker-compose `llama-fallback` service). The backend auto-registers a
# system-managed endpoint at this URL and discovers its model on boot. Points at the docker-network
# hostname by default; only change if you run the fallback llama.cpp elsewhere.
LLAMA_FALLBACK_URL=http://llama-fallback:8080
LLAMA_FALLBACK_MODEL=lfm2.5-230m

# --- Embeddings (Qdrant vector memory) — separate CPU llama.cpp --embedding server ---
EMBEDDING_API_URL=http://localhost:8081
EMBEDDING_API_KEY=sk-no-key-required
EMBEDDING_MODEL=nomic-embed-text-v1.5

# --- Auth (REQUIRED — boot fails if unset) ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

# --- Isolation (per-agent Docker) ---
# Encrypts isolation SSH private keys + VPN WireGuard keys at rest (AES-256-GCM). Optional —
# defaults to JWT_SECRET.
# ISOLATION_ENC_KEY=change-me-to-a-separate-long-random-string
# VPN: profiles in `vpn` network mode get a dedicated gluetun (WireGuard) container. Image pulled
# per profile; the health timeout bounds how long tools wait for the tunnel before erroring out.
# GLUETUN_IMAGE=qmcgaw/gluetun:latest
# AGENT_VPN_HEALTH_TIMEOUT_MS=60000

# --- Fine-tuning ---
# How often the backend polls remote fine-tune servers for tracked-job progress (status + loss
# curve). Only non-terminal jobs are polled, so this costs nothing while nothing is training.
# FINETUNE_POLL_INTERVAL_MS=5000

# --- Skill sandbox ---
SKILL_TIMEOUT_MS=15000
SKILL_FAILURE_THRESHOLD=3
SKILL_WORKER_POOL_SIZE=4

# --- Multi-agent recursion guard ---
MAX_AGENT_HOPS=3

# --- Telegram (optional; alerts + interactive bot; all skipped if token unset) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# Comma-separated chat ids allowed to drive agents (falls back to TELEGRAM_CHAT_ID):
# TELEGRAM_ALLOWED_CHAT_IDS=
# Set false to keep outbound alerts but disable the inbound command bot:
# TELEGRAM_POLLING=true

# --- Logging ---
LOG_LEVEL=info
