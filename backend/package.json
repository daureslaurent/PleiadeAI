{
  "name": "pleiades-backend",
  "version": "0.1.0",
  "private": true,
  "description": "PleiadesAI stateless multi-agent orchestration backend",
  "type": "commonjs",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:assets",
    "build:assets": "node scripts/copy-assets.js",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate:up": "migrate-mongo up",
    "migrate:down": "migrate-mongo down",
    "migrate:status": "migrate-mongo status"
  },
  "dependencies": {
    "@qdrant/js-client-rest": "^1.11.0",
    "agenda": "^5.0.0",
    "cors": "^2.8.5",
    "esbuild": "^0.24.0",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.8.0",
    "multer": "^2.2.0",
    "openai": "^4.73.0",
    "pino": "^9.5.0",
    "socket.io": "^4.8.1",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.13",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.18.1",
    "migrate-mongo": "^11.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
