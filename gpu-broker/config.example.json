{
  "idleTimeoutSec": 0,
  "startTimeoutSec": 300,
  "stopTimeoutSec": 30,
  "stopSettleMs": 2000,
  "swapGraceMs": 1500,
  "maxWaitSec": 180,
  "upstreamRetries": 3,
  "retryDelayMs": 2000,
  "logLevel": "info",
  "dockerSocket": "/var/run/docker.sock",
  "services": [
    {
      "name": "image",
      "listenPort": 1234,
      "container": "image_gen_sd_server",
      "upstreamHost": "127.0.0.1",
      "upstreamPort": 8201,
      "healthPath": "/v1/models",
      "models": ["sd-cpp-local"]
    },
    {
      "name": "vision",
      "listenPort": 8080,
      "container": "llama-server",
      "upstreamHost": "127.0.0.1",
      "upstreamPort": 8202,
      "healthPath": "/health",
      "models": ["REPLACE_WITH_YOUR_CHAT_MODEL_ID"]
    }
  ]
}
