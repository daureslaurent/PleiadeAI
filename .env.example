# PleiadesAI — docker-compose deployment config.
#
# Copy to `.env` (which is gitignored) and fill in. docker-compose interpolates ${VAR} from here.
# Only secret / environment-specific values live here; structural wiring (service hostnames, ports)
# stays in docker-compose.yml. Anything marked REQUIRED will make `docker compose up` fail fast if
# left unset — that is intentional, so a public box never boots with a placeholder secret.

# ============================ Auth (REQUIRED) ============================
# Login for the single-operator command center, and the JWT signing secret.
JWT_SECRET=change-me-to-a-long-random-string-at-least-16-chars
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-to-a-strong-password

# ==================== Inference — hosted LLM (REQUIRED) ====================
# Public/hosted llama.cpp (OpenAI-compatible) endpoint the OVH box can actually reach.
# Must be launched with --jinja so agents emit native tool-calls (see backend/.env.example).
LLAMA_API_URL=https://your-inference-host.example.com
LLAMA_API_KEY=sk-no-key-required
LLAMA_MODEL=local-model
LLAMA_CONTEXT_WINDOW=8192

# ========================= Embeddings (vector memory) =====================
# Model id served by the in-compose `embeddings` service; keep in sync with its --hf model.
EMBEDDING_MODEL=nomic-embed-text-v1.5

# =========================== Web search (SearXNG) =========================
# server.secret_key for the internal SearXNG instance. Generate: openssl rand -hex 32
SEARXNG_SECRET=change-me-to-a-long-random-hex

# ===================== Per-agent isolation (recommended) ==================
# Encrypts isolation SSH/VPN private keys at rest (AES-256-GCM). Falls back to JWT_SECRET if unset;
# set a dedicated value so rotating the login secret doesn't also invalidate stored keys.
ISOLATION_ENC_KEY=change-me-to-a-separate-long-random-string

# ============================ Telegram (optional) =========================
# Leave blank to disable the Telegram alert + interactive bot legs entirely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=

# ============================== Public edge ===============================
# Host port Caddy (the ONLY published service) listens on. 80 = plain HTTP.
PUBLIC_HTTP_PORT=80

# ============================== Misc ======================================
LOG_LEVEL=info

# ========================= Host self-update ===============================
# Directory the backend drops update trigger files into (bind-mounted to ./.update in
# docker-compose; the host systemd watcher installed via tools/updater watches it).
# Only override for non-Docker / custom layouts.
UPDATE_TRIGGER_DIR=/app/.update
