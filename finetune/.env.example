# PleiadesAI fine-tune service — copy to `.env` and fill in.
# Every var is validated at boot by src/config/env.ts; the process exits on any invalid value.

# --- Build profile (GPU architecture) ---
# Consumed by docker-compose at BUILD time (not app config). Normally you DON'T set
# these: run_finetune_server.sh auto-detects the GPU compute capability and picks the
# right profile (Blackwell sm_120 → CUDA 12.8 stack; everything else → CUDA 12.1).
# Uncomment a CUDA_IMAGE below only to PIN a profile and override auto-detection.
#
#   Ampere / Turing  (e.g. RTX 3060, 2070 Super):
# CUDA_IMAGE=nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04
# TORCH_VERSION=2.5.1
# TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121
# FLASH_ATTN_VERSION=2.7.4.post1
# AXOLOTL_REF=v0.6.0
# TRANSFORMERS_VERSION=4.47.1   # axolotl 0.6.0 leaves transformers unbounded; pin it so a
#                               # 2026 build doesn't grab a version needing torchao > 0.5.0
#
#   Blackwell  (e.g. RTX 50-series / 5060 Ti, sm_120):
# CUDA_IMAGE=nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04
# TORCH_VERSION=2.7.1
# TORCH_INDEX_URL=https://download.pytorch.org/whl/cu128
# FLASH_ATTN_VERSION=2.8.3
# AXOLOTL_REF=v0.8.0   # 0.6.0 pins torch 2.5.1; needs a newer tag for torch 2.7
# TRANSFORMERS_VERSION=4.49.0   # bump to match whatever the newer AXOLOTL_REF expects

# --- HTTP API ---
FINETUNE_PORT=8088
# Bearer token every caller must present (Authorization: Bearer <key>). REQUIRED, >= 8 chars.
FINETUNE_API_KEY=change-me-to-a-long-random-secret
# Max size of an uploaded training_data.jsonl, in MB.
MAX_UPLOAD_MB=2048

# --- Filesystem (these are the container paths mapped to host volumes in docker-compose) ---
DATA_DIR=/workspace/data
MODELS_DIR=/workspace/models
RUNS_DIR=/workspace/runs

# --- Training / hardware ---
# Both GPUs on the box.
NUM_GPUS=2
# Default GGUF quantization for the exported model (override per-run via hyperparams.gguf_quant).
GGUF_QUANT=q4_k_m
# Optional HuggingFace token for gated/private base models.
# HF_TOKEN=hf_xxx
# DeepSpeed ZeRO-2 config injected into every Axolotl run (relative to the service cwd).
DEEPSPEED_CONFIG=templates/zero2.json
# Bundled llama.cpp checkout used for HF->GGUF conversion + quantization.
LLAMACPP_DIR=/opt/llama.cpp

# --- Capacity planning (GET /hardware + POST /train pre-flight) ---
# Fraction of each GPU's VRAM held back from the fit estimate (CUDA context, fragmentation).
VRAM_SAFETY_MARGIN=0.10
# Override/assume per-GPU VRAM (GB) when nvidia-smi is unavailable, e.g. planning from a dev box.
# GPU_VRAM_GB_OVERRIDE=16
# Allow auto-switching to FSDP+QLoRA (shard the base across GPUs) for models too big for ZeRO-2.
ENABLE_FSDP=true

# --- Observability ---
NODE_ENV=production
LOG_LEVEL=info
