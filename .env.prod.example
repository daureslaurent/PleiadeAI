# Credentials for the read-only prod tooling: `tools/pleiades-mcp/` (MCP) and `scripts/prod.mjs` (CLI).
# Copy to `.env.prod` (gitignored) and fill in. Real environment variables override this file.
#
# Mint the key in the running app: Settings → API Keys → Create API key. It is shown exactly once.
# The key can only issue GET/HEAD requests, cannot open a websocket, and cannot manage API keys.

PLEIADES_API_URL=https://pleiades.example.com
PLEIADES_API_KEY=plk_xxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- scripts/clone-prod.mjs only -------------------------------------------------------------
# The LOCAL instance the prod snapshot is written into. Its import is destructive (wipe + replace),
# so it needs an operator login, not an API key: these are the target's own AUTH_USERNAME/PASSWORD.
# The script refuses to run unless PLEIADES_LOCAL_URL is a loopback host (override with --force).
PLEIADES_LOCAL_URL=http://localhost:8374
PLEIADES_LOCAL_USERNAME=admin
PLEIADES_LOCAL_PASSWORD=change-me
