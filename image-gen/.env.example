# image-gen configuration. Copy to `.env` and adjust. All values have defaults in docker-compose.yml.

# Container image. leejet publishes only accelerator tags: master-cuda (default), master-vulkan,
# master-sycl, master-musa. Non-NVIDIA hosts must also delete the `deploy` GPU block in compose.
SD_IMAGE=ghcr.io/leejet/stable-diffusion.cpp:master-cuda

# Port the OpenAI-compatible server listens on (and publishes on the host).
SD_PORT=1234
# Host interface to bind. 0.0.0.0 = reachable on the LAN; 127.0.0.1 = localhost only.
SD_BIND=0.0.0.0
# Host-side port. Set this (+ SD_BIND=127.0.0.1) to publish on a private port behind gpu-broker.
#SD_HOST_PORT=8201

# --- Model files (must exist under ./models — populate with run.sh) ---------
# FLUX.2 (upstream docs/flux2.md). Three files: diffusion model + ONE LLM text encoder + VAE —
# FLUX.1's CLIP-L/T5-XXL pair does not exist here.
#
# Default: FLUX.2-klein-9B Q8_0 — distilled (4 steps, cfg 1.0), so it is fast despite being 9B, and
# it is the largest FLUX.2 that fits a 12GB + 8GB pair fully resident. Alternatives:
#   flux-2-klein-9b-Q4_0.gguf   5.6GB  same speed, more VRAM headroom, some quality loss
#   flux-2-klein-4b-Q8_0.gguf   4.3GB  fastest; pair with SD_LLM=Qwen3-4B-Q4_K_M.gguf
#   flux-2-klein-base-9b-*.gguf        NOT distilled: needs SD_CFG_SCALE=4.0 + SD_STEPS=20, and is
#                                      the only variant where a negative prompt actually does anything
# FLUX.2-dev is out of reach here (~19GB weights + a 24B Mistral encoder).
# run.sh derives each download URL from the file name, so swapping any of these needs no script edit.
SD_DIFFUSION_MODEL=flux-2-klein-9b-Q8_0.gguf
SD_LLM=Qwen3-8B-Q4_K_M.gguf
SD_VAE=flux2-vae.safetensors

# --- Generation defaults ----------------------------------------------------
# sd-server's OpenAI route reads ONLY prompt/n/size/output_format from the request body; everything
# else comes from these CLI defaults (PleiadesAI overrides them per call via <sd_cpp_extra_args>).
# Leave SD_CFG_SCALE at 1.0 on klein: it is guidance-distilled and real CFG > 1 burns the image.
# sd-server's own stock default is 7.0, which is exactly that failure mode.
SD_CFG_SCALE=1.0
SD_SAMPLING_METHOD=euler
SD_STEPS=4

# --- Placement / VRAM -------------------------------------------------------
# Where each module computes. Diffusion on the 12GB card, LLM encoder + VAE on the 8GB one — all
# resident, nothing streams. NOTE: ggml's cuda0/cuda1 can be the reverse of nvidia-smi's indices;
# check the load log to see which card took the big slice. Single-GPU boxes: drop this to `te=cpu`
# (keeps the encoder off the GPU) or add SD_EXTRA_ARGS=--offload-to-cpu.
SD_BACKEND=diffusion=cuda0,te=cuda1,vae=cuda1
# Extra raw sd-server flags, appended verbatim. Needed only when the weights do NOT fit:
#SD_EXTRA_ARGS=--offload-to-cpu
