# image-gen configuration. Copy to `.env` and adjust. All values have defaults in docker-compose.yml.

# Container image. Default is CPU/Vulkan master. For NVIDIA, use a CUDA tag if published
# (e.g. ghcr.io/leejet/stable-diffusion.cpp:master-cuda) and uncomment the `deploy` GPU block.
SD_IMAGE=ghcr.io/leejet/stable-diffusion.cpp:master

# Port the OpenAI-compatible server listens on (and publishes on the host).
SD_PORT=1234
# Host interface to bind. 0.0.0.0 = reachable on the LAN; 127.0.0.1 = localhost only.
SD_BIND=0.0.0.0

# --- Model files (must exist under ./models — populate with run.sh) ---------
# FLUX.1-dev GGUF (non-commercial license; higher quality, needs ~20-28 steps + guidance ~3.5,
# unlike schnell's 4-step). Q4_0 = low VRAM, Q8_0 = higher quality.
SD_DIFFUSION_MODEL=flux1-dev-Q4_0.gguf
SD_T5XXL=t5-v1_1-xxl-encoder-Q4_K_M.gguf
SD_CLIP_L=clip_l.safetensors
SD_VAE=ae.safetensors
