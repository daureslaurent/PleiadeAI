# image-gen configuration. Copy to `.env` and adjust. All values have defaults in docker-compose.yml.

# Container image. leejet publishes only accelerator tags: master-cuda (default), master-vulkan,
# master-sycl, master-musa. For a non-NVIDIA host, switch the tag AND delete the `deploy` GPU block.
SD_IMAGE=ghcr.io/leejet/stable-diffusion.cpp:master-cuda

# Port the OpenAI-compatible server listens on (and publishes on the host).
SD_PORT=1234
# Host interface to bind. 0.0.0.0 = reachable on the LAN; 127.0.0.1 = localhost only.
SD_BIND=0.0.0.0
# Host-side port. Set this (+ SD_BIND=127.0.0.1) to publish on a private port behind gpu-broker.
#SD_HOST_PORT=8201

# --- Model files (must exist under ./models — populate with run.sh) ---------
# FLUX.1-dev GGUF (non-commercial license; ~20-28 steps + distilled guidance ~3.5, unlike the
# 4-step schnell). Quant ladder from city96/FLUX.1-dev-gguf — pick the largest that fits VRAM
# *after* the text encoders are pushed to CPU (SD_BACKEND=te=cpu, the default):
#   Q4_K_S ~6.9GB (default, fits an 8GB card) < Q5_K_S ~8.3GB < Q6_K ~9.9GB < Q8_0 ~12.7GB (best).
# Prefer the _K quants over the legacy Q4_0 at the same size. Anything that does NOT fit outright
# needs SD_EXTRA_ARGS (see below). run.sh downloads whichever FLUX.1-dev quant you name here.
SD_DIFFUSION_MODEL=flux1-dev-Q4_K_S.gguf
SD_T5XXL=t5-v1_1-xxl-encoder-Q4_K_M.gguf
SD_CLIP_L=clip_l.safetensors
SD_VAE=ae.safetensors

# --- Generation defaults ----------------------------------------------------
# sd-server's OpenAI route reads ONLY prompt/n/size/output_format from the request body; everything
# else comes from these CLI defaults (PleiadesAI overrides them per call via <sd_cpp_extra_args>).
# Leave SD_CFG_SCALE at 1.0 on FLUX: it is guidance-distilled, and real CFG > 1 burns the image
# (upstream docs/flux.md). SD_GUIDANCE is the distilled scale FLUX actually uses — a different knob.
SD_CFG_SCALE=1.0
SD_GUIDANCE=3.5
SD_SAMPLING_METHOD=euler
SD_STEPS=24

# --- Placement / VRAM -------------------------------------------------------
# Where each module computes. The default keeps the text encoders on CPU (upstream's --clip-on-cpu,
# now deprecated in favour of this spelling), leaving the GPU to the diffusion weights. Pin
# explicitly on a multi-GPU box, e.g. diffusion=cuda0,te=cpu,vae=cuda0.
SD_BACKEND=te=cpu
# Extra raw sd-server flags, appended verbatim. Only needed when the diffusion weights do NOT fit in
# VRAM — e.g. Q8_0 (~12.7GB) on a 12GB card, where the weights must live in RAM and stream in:
#SD_EXTRA_ARGS=--params-backend diffusion=cpu --max-vram cuda0=11 --stream-layers
