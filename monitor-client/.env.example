# Copy to .env before `docker compose up -d`. Every value is optional; the defaults shown are what
# the service uses when the variable is absent.

# Listen address. With network_mode: host this is a host port directly.
MONITOR_PORT=9101
# 0.0.0.0 exposes it to the LAN. Use 127.0.0.1 to force access through an SSH tunnel.
MONITOR_BIND=0.0.0.0

# Shared secret, sent as `X-API-Key: <key>` or `Authorization: Bearer <key>`.
# LEAVE EMPTY ONLY ON A TRUSTED LAN — empty means anyone who can reach the port can read the metrics.
# Generate one with: openssl rand -hex 32
MONITOR_API_KEY=

# Comma-separated "label:path" pairs. The path is as seen *inside* the container, so anything beyond
# the root filesystem needs a matching :ro bind mount added to docker-compose.yml.
# e.g. MONITOR_DISKS=/:/host/rootfs,/models:/host/models
MONITOR_DISKS=/:/host/rootfs

# Blocking window used to measure CPU busy-time, in ms. It is the request's floor latency, so keep it
# small. Set to 0 to skip sampling entirely: CPU% and network rates are then measured across the gap
# since the previous request instead (good for a fixed-interval poller, null on the very first call).
MONITOR_CPU_SAMPLE_MS=200

# Override if nvidia-smi is not on PATH inside the container.
NVIDIA_SMI=nvidia-smi
